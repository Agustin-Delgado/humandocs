{
	"name": "@human-kit/humandocs",
	"version": "0.0.0",
	"description": "A documentation kit for Svelte and SvelteKit — docs shell components, live demos with source, generated API reference tables, and a shiki dual-theme preset.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Agustin-Delgado/humandocs.git",
		"directory": "packages/humandocs"
	},
	"homepage": "https://github.com/Agustin-Delgado/humandocs/tree/main/packages/humandocs",
	"bugs": "https://github.com/Agustin-Delgado/humandocs/issues",
	"keywords": ["svelte", "sveltekit", "documentation", "docs", "fumadocs", "shiki"],
	"svelte": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./components": {
			"types": "./dist/components/index.d.ts",
			"svelte": "./dist/components/index.js",
			"default": "./dist/components/index.js"
		},
		"./content": {
			"types": "./dist/content/index.d.ts",
			"default": "./dist/content/index.js"
		},
		"./highlighter": {
			"types": "./dist/highlighter/index.d.ts",
			"default": "./dist/highlighter/index.js"
		},
		"./vite": {
			"types": "./dist/vite/index.d.ts",
			"default": "./dist/vite/index.js"
		},
		"./theme": {
			"types": "./dist/theme/index.d.ts",
			"svelte": "./dist/theme/index.js",
			"default": "./dist/theme/index.js"
		},
		"./theme.css": "./dist/theme.css",
		"./ambient": {
			"types": "./dist/ambient.d.ts"
		},
		"./package.json": "./package.json"
	},
	"files": ["dist", "!dist/**/*.test.*"],
	"scripts": {
		"package": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "pnpm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"dependencies": {
		"shiki": "^4.3.0"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"svelte": "^5.0.0",
		"vite": "^6.0.0 || ^7.0.0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		}
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/package": "^2.3.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^20",
		"publint": "^0.2.0",
		"svelte": "^5.41.0",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"vite": "^7.1.10"
	}
}
