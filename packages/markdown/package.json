{
	"name": "@human-kit/markdown",
	"version": "0.3.0",
	"description": "A markdown preprocessor for Svelte built on unified — components in markdown, frontmatter metadata, runes-compatible blueprints, and pluggable async syntax highlighting.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Agustin-Delgado/humandocs.git",
		"directory": "packages/markdown"
	},
	"homepage": "https://github.com/Agustin-Delgado/humandocs/tree/main/packages/markdown",
	"bugs": "https://github.com/Agustin-Delgado/humandocs/issues",
	"keywords": [
		"svelte",
		"markdown",
		"preprocessor",
		"unified",
		"remark",
		"rehype",
		"mdsvex"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./shiki": {
			"types": "./dist/shiki.d.ts",
			"default": "./dist/shiki.js"
		},
		"./vite": {
			"types": "./dist/vite.d.ts",
			"default": "./dist/vite.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"hk-extract-api": "./dist/cli/extract-api.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "tsc -p ."
	},
	"dependencies": {
		"property-information": "^7.1.0",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"shiki": "^4.3.0",
		"ts-morph": "^28.0.0",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.0.0",
		"vfile": "^6.0.3",
		"yaml": "^2.8.0"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"vite": "^6.0.0 || ^7.0.0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		}
	},
	"devDependencies": {
		"vite": "^7.1.10",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/mdast": "^4.0.4",
		"@types/node": "^20",
		"rehype-slug": "^6.0.0",
		"svelte": "^5.41.0",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	}
}
