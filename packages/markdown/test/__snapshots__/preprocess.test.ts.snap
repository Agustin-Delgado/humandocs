exports[`humandocsMarkdown output > svelte components pass through untouched 1`] = `
"<script module>
	export const metadata = {"title":"Components"};
</script>

<script>
	import Counter from './counter.svelte';
</script>

<h1>Components</h1>
<p>Inline <Counter start={1} /> in a sentence.</p>
<Counter start={2}>
	Tight children stay raw (no blank lines).
</Counter>
<Counter start={3}>
<p><strong>Loose</strong> children are processed as markdown.</p>
</Counter>
"
`;

exports[`humandocsMarkdown output > user scripts are hoisted out of the markdown 1`] = `
"<script module>
	export const metadata = {"title":"Scripts"};

	export const shared = 42;

	export function helper() {
		return shared;
	}
</script>

<script lang="ts">
	let count: number = 0;

	function increment() {
		count += 1;
	}
</script>

<h1>Scripts</h1>
<p>Count starts at zero.</p>
<p><button onclick={increment}>Increment</button></p>
"
`;
