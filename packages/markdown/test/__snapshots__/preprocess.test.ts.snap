exports[`humandocsMarkdown output > default blueprint wraps content and overrides h2 1`] = `
"<script module>
	export const metadata = {"title":"With blueprint"};
</script>

<script>
	import Blueprint__, * as blueprintModule__ from '<BLUEPRINTS>/default.svelte';
</script>

<Blueprint__ {metadata}>
<h1>Title</h1>
<blueprintModule__.h2>Overridden heading</blueprintModule__.h2>
<p>Paragraph inside the blueprint.</p>
</Blueprint__>
"
`;

