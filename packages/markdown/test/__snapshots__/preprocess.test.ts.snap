exports[`humandocsMarkdown output > braces and backticks in prose are entity-escaped 1`] = `
"<script module>
	export const metadata = {"title":"Entities"};
</script>

<h1>Entities</h1>
<p>Braces &#123; not an expression &#125; in prose, plus an inline <code>&#123;#each item&#125;</code> block.</p>
<h2>Heading two</h2>
<table>
<thead>
<tr>
<th>Column</th>
<th>Value &#123; x &#125;</th>
</tr>
</thead>
<tbody>
<tr>
<td>pipes</td>
<td>braces &#123;&#125;</td>
</tr>
</tbody>
</table>
<p>A <a href="https://example.com" title="title with &#123;braces&#125;">link</a> too.</p>
"
`;

exports[`humandocsMarkdown output > code blocks with a sync highlighter 1`] = `
"<script module>
	export const metadata = {"title":"Code"};
</script>

<h1>Code</h1>
<!-- svelte-ignore a11y_no_noninteractive_tabindex -->
<pre class="fake" data-lang="svelte" data-meta=""><code><script>
	let &#123; open = $bindable(false) &#125; = $props();
</script>

&#123;#if open&#125;
	<p>&#123;open&#125;</p>
&#123;/if&#125;</code></pre>
<!-- svelte-ignore a11y_no_noninteractive_tabindex -->
<pre class="fake" data-lang="ts" data-meta="twoslash"><code>const x: number = 1;</code></pre>
"
`;

exports[`humandocsMarkdown output > code blocks without a highlighter fall back to pre/code 1`] = `
